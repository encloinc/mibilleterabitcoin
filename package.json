{
  "name": "mibilleterabitcoin-monorepo",
  "packageManager": "npm@11.3.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "crates/*"
  ],
  "scripts": {
    "build:wasm": "npm run build:wasm --workspace mibilleterabitcoin-common",
    "dev": "npm run dev:mibilleterabitcoin",
    "dev:mibilleterabitcoin": "npm run build:wasm && turbo run dev --filter=mibilleterabitcoin"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
